# Miro API Settings
# Required: Miro REST API access token
MIRO_ACCESS_TOKEN=

# Optional: Miro API base URL (default: https://api.miro.com/v2)
MIRO_API_BASE_URL=https://api.miro.com/v2

# Optional: Default board ID for update/append when --board-id is omitted
MIRO_DEFAULT_BOARD_ID=

# AIPO Settings
# Optional: Log output directory (default: ./logs)
AIPO_LOG_DIR=./logs

# Optional: Runner identifier (default: miro-flow-maker)
AIPO_RUNNER_ID=miro-flow-maker

# Optional: Force all executions to dry-run mode (true/false/1/0, default: false)
AIPO_DRY_RUN=false

# Optional: Log level (DEBUG/INFO/WARNING/ERROR, default: INFO)
AIPO_LOG_LEVEL=INFO
